# Template for the Marigold Ops web app local environment.
# Copy to .env and fill in real values (the real .env is git-ignored).

# --- Cognito ---
COGNITO_POOL_ID=ap-south-1_xxxxxxxxx
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_DOMAIN=ijor-marketplace
COGNITO_REDIRECT_URI=http://localhost:8000/auth/callback

# --- S3 (image hosting) ---
S3_BUCKET=ijorethnicpartners
S3_REGION=ap-south-1
S3_PREFIX=myntra/

# --- Local dev toggles ---
# AUTH_DISABLED=1 logs in a synthetic dev@local user and skips Cognito.
AUTH_DISABLED=1
LEDGER_LOCAL_PATH=src/web/runtime/ledger.json
